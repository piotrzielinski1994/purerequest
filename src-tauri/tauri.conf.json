{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "purerequest",
  "version": "0.1.0",
  "identifier": "com.pzielinski.purerequest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "purerequest",
        "width": 1000,
        "height": 700,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5NkRCQTc3RDVDMUVBOTEKUldTUjZzSFZkN3B0NlMyZE1DNjNKMVJCWE5IRHg4eEo4SnFQUlV3SDY2Y1JJdXRKRndoRFFmamcK",
      "endpoints": [
        "https://github.com/piotrzielinski1994/purerequest/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
